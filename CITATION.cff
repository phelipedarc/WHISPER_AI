    given-names: Phelipe
    email: phelipedarc@gmail.com
version: 0.0.1.dev0
license: GPL-3.0-or-later
repository-code: "https://github.com/phelipedarc/WHISPER_AI"
url: "https://github.com/phelipedarc/WHISPER_AI"
keywords:
  - astronomy
  - transients
  - supernovae
  - kilonovae
  - bayesian-inference
  - simulation-based-inference
  - light-curves
